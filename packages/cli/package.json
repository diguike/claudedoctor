{
  "name": "@claudedoctor/cli",
  "version": "0.0.0",
  "description": "claudedoctor — Claude Doctor CLI: health-check your local Claude Code, prescribe fixes, and re-check.",
  "type": "module",
  "bin": {
    "claudedoctor": "./bin/claudedoctor.mjs",
    "cdoc": "./bin/claudedoctor.mjs"
  },
