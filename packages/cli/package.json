{
  "name": "@diguike/claudedoctor",
  "version": "0.2.3",
  "description": "Evidence-first diagnostics for Claude Code credentials, client source, network policy, and configuration hygiene.",
  "type": "module",
  "bin": {
    "claudedoctor": "./bin/claudedoctor.mjs",
    "cdoc": "./bin/claudedoctor.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "diagnostics",
    "security-audit",
    "configuration",
    "cli",
    "developer-tools"
  ],
  "homepage": "https://github.com/diguike/claudedoctor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diguike/claudedoctor.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/diguike/claudedoctor/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && esbuild src/cli.ts --bundle --minify --external:yaml --platform=node --format=esm --target=node20 --outfile=dist/cli.js",
    "prepack": "npm run bundle",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@clack/prompts": "^1.7.0",
    "@claudedoctor/core": "workspace:*",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "picocolors": "^1.1.1"
  },
  "license": "MIT",
  "author": "递归客"
}
