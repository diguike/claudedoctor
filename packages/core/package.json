{
  "name": "@claudedoctor/core",
  "version": "0.0.0",
  "private": true,
  "description": "Isomorphic evidence classification and diagnostics shared by the CLI and web. No I/O side effects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT"
}
